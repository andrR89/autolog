**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# iOS / CocoaPods (regenerado por `pod install`)
/ios/Pods/
/ios/.symlinks/
/ios/Flutter/Flutter.framework
/ios/Flutter/Flutter.podspec
/ios/Runner.xcworkspace/xcuserdata/
/ios/Runner.xcodeproj/xcuserdata/

# Supabase CLI (refs locais, pooler URL, etc — não versionar)
/supabase/.temp/

# Drift web worker — artefatos auxiliares do `dart compile js` (deps + sourcemap).
# O drift_worker.dart fonte e o drift_worker.js compilado SÃO versionados
# (build reprodutível). Só estes dois auxiliares regeneram a cada compile.
/web/drift_worker.js.deps
/web/drift_worker.js.map
